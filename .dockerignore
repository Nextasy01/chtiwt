# keep the build context small + reproducible

# build artifacts
/chtiwt
/chtiwt.exe
*.exe
*.test
*.out
*.prof
coverage.html
coverage.txt

# go workspaces
go.work
go.work.sum

# runtime state (HLS segments) — generated by the running container
/state/

# secrets / env
.env
.env.example

# logs
*.log

# version control
.git/
.gitignore
.gitattributes

# CI configs (not needed inside the image)
.github/

# Claude / graphify tooling — not needed at build time
.claude/
graphify-out/

# editors / IDE
.idea/
.vscode/
*.swp
*~

# OS junk
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
._*
